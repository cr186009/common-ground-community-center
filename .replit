modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"
packages = ["psmisc"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Community Center"

[[workflows.workflow]]
name = "Community Center"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && PORT=5000 pnpm exec next dev --hostname 0.0.0.0 -p 5000"
waitForPort = 5000
ensurePreviewReachable = "/"
router = "path"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Build Community"
mode = "sequential"
author = 38167140

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && pnpm run build"

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["pnpm", "run", "start"]
build = ["pnpm", "run", "build"]
